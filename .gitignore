node_modules
dist
.DS_Store
server/public
vite.config.ts.*
*.tar.gz
.config/replit/.semgrep/

# Environment files (sensitive data)
.env
.env.local
.env.production
.env.production.local

# Logs
logs/
*.log

# Uploads
uploads/

# Backups
backups/

# Android/iOS signing keys (NEVER commit these)
*.jks
*.keystore
android/app/signing.properties
ios/App/Pods/
# Loose key dumps that ops occasionally drops next to the repo on the
# VPS while rotating the signing identity. Even if their contents look
# innocuous, they are not source code and must never end up in a commit.
# Anchored to the repo root so we don't accidentally swallow legitimate
# fixtures like `tests/data/sample_base64.txt` deeper in the tree.
/key.txt
/*_base64.txt

# Android/iOS build outputs & platform
android/
ios/

# But DO track the source code of our in-repo Capacitor plugins —
# only the generated platform copy at the repo root (created by
# `npx cap sync`) and per-plugin build output should be ignored.
!native-plugins/*/android/
!native-plugins/*/android/**
!native-plugins/*/ios/
!native-plugins/*/ios/**
native-plugins/*/android/build/
native-plugins/*/android/.gradle/
native-plugins/*/android/.idea/
native-plugins/*/android/local.properties
native-plugins/*/ios/Pods/
native-plugins/*/ios/build/

# Build outputs
android/app/build/
.cache/
client/public/downloads/*.apk
client/public/downloads/*.aab
dist/public/downloads/*.apk
dist/public/downloads/*.aab
# Generated by scripts/server/refresh-android-binaries.sh — derived
# from package.json + the freshly downloaded artifacts. Tracking it
# would create a constant churn on every release without adding any
# information that isn't already in package.json.
client/public/downloads/manifest.json
dist/public/downloads/manifest.json
ios/App/build/ts_errors.txt
Brackeys.zip/

.fake
.git.backup.*
