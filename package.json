{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development DOTENV_CONFIG_PATH=.env tsx -r dotenv/config server/index.ts",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production DOTENV_CONFIG_PATH=.env.production.local node -r dotenv/config dist/index.cjs",
    "check": "tsc",
    "check:types": "tsc --noEmit",
    "i18n:audit": "node scripts/audit-i18n.mjs",
    "i18n:audit:strict": "node scripts/audit-i18n.mjs --strict",
    "quality:gate": "npm run check:types && npm run i18n:audit",
    "security:audit": "npm audit --audit-level=high",
    "security:smoke": "node scripts/security-smoke.mjs",
    "security:smoke:challenges": "node scripts/smoke-challenge-permissions.mjs",
    "security:smoke:challenges:deterministic": "node scripts/smoke-challenge-permissions.mjs --reset-sensitive-limiter",
    "security:smoke:ws-heartbeat": "node scripts/smoke-ws-heartbeat.mjs",
    "security:smoke:settlement-idempotency": "tsx scripts/smoke-settlement-idempotency.ts",
    "security:csp": "node scripts/validate-csp-prod.mjs",
    "security:check": "npm run security:audit && npm run security:smoke",
    "security:gate": "npm run check:types && npm run security:audit",
    "smoke:ai-admin": "node scripts/smoke-ai-admin.mjs",
    "admin:rotate-password": "node scripts/rotate-admin-password.mjs",
    "db:push": "drizzle-kit push",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:doctor": "npx cap doctor"
  },
