# Force LF line endings for shell scripts (critical for Linux servers)
*.sh text eol=lf
entrypoint.sh text eol=lf
Dockerfile text eol=lf

# Keep Windows line endings for Windows-only files
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Note: APK/AAB binaries are NOT stored in this repo. The GitHub Actions
# Android build pipeline publishes them directly to GitHub Releases
# (tag: latest-android). The Hostinger VPS pulls them at deploy time via
# `scripts/server/refresh-android-binaries.sh` straight from the Release
# CDN — keeping git history clean and avoiding LFS / merge-conflict pain.
