{
    "github.copilot.enable": {
        "plaintext": true,
        "markdown": true,
        "scminput": true
    },
    "java.configuration.updateBuildConfiguration": "interactive",
    "terminal.integrated.scrollback": 4000,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/coverage/**": true,
        "**/logs/**": true,
        "**/backups/**": true,
        "**/uploads/**": true,
        "**/output/**": true,
        "**/android/build/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/coverage": true,
        "**/logs": true,
        "**/backups": true,
        "**/uploads": true,
        "**/output": true,
        "**/android/build": true
    },
    "extensions.experimental.affinity": {
        "GitHub.copilot-chat": 1,
        "GitHub.copilot": 1,
        "Continue.continue": 2,
        "Anthropic.claude-code": 3,
        "Sixth.sixth-ai": 4
    },
    "chat.agent.maxRequests": 5000,
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "--root",
                "C:\\Users\\cex\\Desktop\\vixo"
            ]
        },
        "puppeteer": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ]
        }
    },
    "localAIAssistant.apiLLM.config.model": "http://localhost:11434/api/tags",
    "localAIAssistant.capabilities.allowFileEdits": true
}