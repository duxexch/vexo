<!--
  Add the following inside the host app's <manifest> ... <application>
  block (typically android/app/src/main/AndroidManifest.xml). The
  permissions are required for self-managed Telecom + foreground
  service starts on Android 12+; the service entries register the FCM
  receiver and the foreground wake service used to surface incoming
  calls within the 5-second OS budget.

  ===========================================================
  IMPORTANT — WebView permission delegation (Task #124 fix)
  ===========================================================
  The friend-call mic/camera flow depends on the WebView's
  `WebChromeClient.onPermissionRequest` mapping
  `RESOURCE_AUDIO_CAPTURE` / `RESOURCE_VIDEO_CAPTURE` to Android
  runtime permission requests. Capacitor's default
  `BridgeWebChromeClient` does this correctly out of the box. The
  bug we fixed in Task #124 was on the JS side — the call code
  invoked `getUserMedia` BEFORE asking the host plugin to request
  the runtime permission, so the WebView saw an unprivileged host
  and the bridge auto-denied without surfacing the OS dialog.

  Required host-app contract:

   1. DO NOT replace `BridgeWebChromeClient` in your `MainActivity`.
      If you must override it (e.g. to add custom file-chooser
      behaviour), your subclass MUST extend `BridgeWebChromeClient`
      and forward `onPermissionRequest` / `onPermissionRequestCanceled`
      to `super`. A minimal wrapper that only handles file uploads
      will silently break the friend-call mic/camera flow.

      // MainActivity.kt — correct pattern
      class CustomChromeClient(bridge: Bridge)
          : BridgeWebChromeClient(bridge) {
          override fun onShowFileChooser(/* ... */): Boolean { /* ... */ }
          // onPermissionRequest is inherited from BridgeWebChromeClient
          // and MUST NOT be overridden without calling super.
      }

   2. The JS layer (`client/src/components/games/VoiceChat.tsx`,
      `client/src/hooks/use-call-session.tsx`,
      `client/src/components/chat/private-call-layer.tsx`) calls
      `requestCallMediaPermissions` on this plugin BEFORE invoking
      `getUserMedia`. This is the primary fix and the path you should
      preserve when adding new call entrypoints.

  Verify with logcat:
      adb logcat -s Capacitor:I chromium:I AndroidRuntime:E
  Tap "Voice call" on a fresh install — you should see:
   - the in-app rationale modal,
   - the OS runtime mic permission dialog within ~250 ms of "Allow",
   - `getUserMedia` resolving with a real `MediaStream`.
  If the OS dialog never appears the plugin's
  `requestCallMediaPermissions` is not being called before
  `getUserMedia` — re-check the JS preflight order.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
      Friend-call media permissions (added in task #88). The plugin's own
      AndroidManifest.xml already declares these via Gradle manifest
      merging, but they are listed here so host-app maintainers see the
      complete picture in one place.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!--
      MODIFY_AUDIO_SETTINGS must be present in the merged manifest
      because Capacitor's BridgeWebChromeClient bundles it together
      with RECORD_AUDIO when the WebView issues a mic permission
      request. See the plugin manifest for the full root-cause note.
    -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>

        <!-- Self-managed Telecom ConnectionService -->
        <service
            android:name="click.vixo.nativecallui.CallConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <!-- Foreground wake service (started by FCM and the plugin) -->
        <service
            android:name="click.vixo.nativecallui.IncomingCallForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- Firebase Cloud Messaging receiver (high-priority data wakes) -->
        <service
            android:name="click.vixo.nativecallui.CallFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
