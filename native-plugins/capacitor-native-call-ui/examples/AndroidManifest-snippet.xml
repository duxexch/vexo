<!--
  Add the following inside the host app's <manifest> ... <application>
  block (typically android/app/src/main/AndroidManifest.xml). The
  permissions are required for self-managed Telecom + foreground
  service starts on Android 12+; the service entries register the FCM
  receiver and the foreground wake service used to surface incoming
  calls within the 5-second OS budget.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
      Friend-call media permissions (added in task #88). The plugin's own
      AndroidManifest.xml already declares these via Gradle manifest
      merging, but they are listed here so host-app maintainers see the
      complete picture in one place.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>

        <!-- Self-managed Telecom ConnectionService -->
        <service
            android:name="click.vixo.nativecallui.CallConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <!-- Foreground wake service (started by FCM and the plugin) -->
        <service
            android:name="click.vixo.nativecallui.IncomingCallForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- Firebase Cloud Messaging receiver (high-priority data wakes) -->
        <service
            android:name="click.vixo.nativecallui.CallFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
