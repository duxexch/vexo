# ==========================================================
# VEX Platform - Complete Production Example (Web + Mobile)
# ==========================================================
# Copy to .env and replace all placeholder values.
# Keep this file free of real secrets.

# ==========================================================
# 0) Configuration Precedence (Admin Panel vs ENV)
# ==========================================================
# - Infra/secrets/integrations credentials: managed by ENV.
# - App settings edited in Admin panel are DB-backed and take precedence at runtime.
#   Examples: store links, feature flags, auth toggles, social platform enable/disable.
# - Social platform OAuth/OTP credentials are primarily managed in Admin > Social Platforms.
# - If you update ENV values, restart backend services to apply changes.

# ==========================================================
# 1) Core App Runtime (Required)
# ==========================================================
NODE_ENV=production
PORT=3001
APP_PORT=3001
APP_URL=https://vixo.click
TZ=UTC
LOG_LEVEL=INFO
LOG_DIR=./logs
VEX_DEV_MODE=false

# ==========================================================
# 2) Traefik / Edge Routing (Required for HTTPS reverse proxy)
# ==========================================================
ACME_EMAIL=info@vixo.click
TRAEFIK_EXTERNAL_NETWORK=vex-traefik

# ==========================================================
# 3) Database (Required)
# ==========================================================
POSTGRES_USER=vex_user
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=vex_db

# Needed when app runs outside docker-compose (direct node / scripts)
DATABASE_URL=postgresql://vex_user:replace_with_strong_password@localhost:5432/vex_db

DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=30
DB_POOL_MIN=5

# ==========================================================
# 4) Redis (Required)
# ==========================================================
REDIS_PASSWORD=replace_with_strong_redis_password

# Needed when app runs outside compose
REDIS_URL=redis://:replace_with_strong_redis_password@localhost:6379

# ==========================================================
# 5) Object Storage - MinIO (Required for uploads/assets)
# ==========================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_BUCKET=vex-uploads
# Optional: pin MinIO image version in docker-compose.prod.yml (tag or digest)
# Example tag: minio/minio:RELEASE.2025-03-12T18-04-18Z
# Example digest: minio/minio@sha256:replace_with_real_digest
MINIO_IMAGE=minio/minio:latest

# App-side MinIO connection (used by server runtime)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace_with_strong_minio_password
MINIO_USE_SSL=false

# ==========================================================
# 6) Security / JWT / Encryption (Required)
# Generate each secret with at least 64 chars.
# ==========================================================
SESSION_SECRET=replace_with_very_long_random_secret
JWT_SIGNING_KEY=replace_with_very_long_random_secret
ADMIN_JWT_SECRET=replace_with_very_long_random_secret

# Server resolves these with fallback, keep explicit in production.
JWT_USER_SECRET=replace_with_very_long_random_secret
JWT_ADMIN_SECRET=replace_with_very_long_random_secret

SECRETS_ENCRYPTION_KEY=replace_with_very_long_random_secret
ENFORCE_SESSION_FINGERPRINT=true

# Account lifecycle recovery controls
ACCOUNT_RECOVERY_CODE_EXPIRY_MINUTES=20
ACCOUNT_RESTORE_WINDOW_DAYS=30

# Reset/recovery abuse protection controls
AUTH_RESET_REQUEST_MAX_PER_15M=6
AUTH_RESET_IDENTIFIER_MAX_PER_HOUR=4
AUTH_RESET_CONFIRM_MAX_PER_15M=8
AUTH_RECOVERY_CONFIRM_MAX_PER_15M=8
AUTH_RESET_BRUTE_WINDOW_SECONDS=900
AUTH_RESET_BRUTE_MAX_FAILURES=6
AUTH_RESET_BRUTE_BLOCK_SECONDS=1800
AUTH_RESET_ALERT_COOLDOWN_SECONDS=300

# ==========================================================
# 7) Admin Bootstrap / Recovery (Required)
# ==========================================================
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_admin_password
ADMIN_BOOTSTRAP_EMAIL=info@vixo.click
ADMIN_RECOVERY_EMAIL=info@vixo.click

# Leave empty to disable forced reset on startup
ADMIN_RESET_USERNAME=
ADMIN_RESET_PASSWORD=
ADMIN_RESET_EMAIL=

# ==========================================================
# 8) Migrations / Startup Controls
# ==========================================================
SKIP_MIGRATIONS=false
ALLOW_FORCE_MIGRATIONS=false
SEED_DATABASE=true
MIGRATION_TIMEOUT=120

# ==========================================================
# 9) Node Cluster / Concurrency
# ==========================================================
NODE_CLUSTER_ENABLED=false
WEB_CONCURRENCY=2

# ==========================================================
# 10) AI Service (sam9) - Required when AI is enabled
# ==========================================================
AI_AGENT_ENABLED=true
AI_AGENT_BASE_URL=http://vex-ai-agent:3100
AI_AGENT_SHARED_TOKEN=replace_with_strong_ai_shared_token
AI_AGENT_TIMEOUT_MS=900
AI_AGENT_PAYLOAD_SALT=replace_with_strong_ai_payload_salt

# AI service internals
AI_AGENT_NAME=sam9
AI_AGENT_DATA_DIR=/app/data
AI_AGENT_PRIVACY_SALT=replace_with_strong_ai_privacy_salt
AI_AGENT_MAX_RAW_EVENTS=5000
AI_AGENT_MAX_PROJECT_SNAPSHOTS=300

# ==========================================================
# 11) Email Service (Choose one provider)
# EMAIL_PROVIDER: smtp | sendgrid | console
# ==========================================================
EMAIL_PROVIDER=smtp

# SMTP
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@your-domain.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=noreply@your-domain.com

# SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_FROM_EMAIL=

# ==========================================================
# 12) SMS/OTP Service (Choose one provider)
# SMS_PROVIDER: twilio | custom | webhook | console
# ==========================================================
SMS_PROVIDER=console

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Generic SMS webhook (optional)
SMS_WEBHOOK_URL=

# ==========================================================
# 13) Social Login / OAuth Integrations
# Runtime supports dual-source OAuth credentials with explicit resolution mode.
# Default mode is env-first (project files first, Admin panel fallback).
# You can override per provider from Admin panel via oauthResolutionMode.
# If both Admin panel and ENV are configured and differ, Admin panel will show conflict diagnostics.
# Avoid dual-maintenance for the same provider unless you intentionally use staged credential rotation.
# Supported OAuth providers in runtime:
# google, facebook, apple, twitter, discord, github, linkedin
# For apple/discord/github/linkedin, configure client_id/client_secret/callback_url in admin panel.
# ==========================================================
GOOGLE_CLIENT_ID=460797952589-r90j0f4d7j346d8m216v9n5sgmgh821d.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPES=openid,email,profile
# Android Google OAuth client ID (recommended key)
GOOGLE_ANDROID_CLIENT_ID=460797952589-j4go2m5gdh8obj4toeu4nqp4fvu1205o.apps.googleusercontent.com
# Legacy alias for backward compatibility (keep same value if used)
GOOGLE_CLIENT_ID_ANDROID=460797952589-j4go2m5gdh8obj4toeu4nqp4fvu1205o.apps.googleusercontent.com
GOOGLE_ANDROID_LOGIN_MODE=sdk-only
# Leave false unless you intentionally allow web client fallback for Android auth
GOOGLE_ANDROID_ALLOW_WEB_CLIENT_FALLBACK=false
# Optional explicit allow-list for Google token audiences (comma-separated)
GOOGLE_ALLOWED_AUDIENCES=
# Request Google refresh token (adds access_type=offline + consent)
GOOGLE_REQUEST_OFFLINE_ACCESS=false
GOOGLE_ANDROID_PACKAGE_NAME=click.vixo.app
GOOGLE_ANDROID_SHA1=7F:8D:A0:CB:12:42:1A:7F:90:6D:43:2E:6C:C2:96:1A:DD:AE:C8:B8
GOOGLE_ANDROID_SHA256=46:67:5A:1E:EA:17:A4:76:B9:1F:B3:11:3F:13:6F:85:3E:8B:65:BC:48:24:6C:91:BB:0E:BD:25:E7:EA:A5:CB
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TELEGRAM_BOT_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# OAuth runtime safety and policy flags
# Disable providers globally (comma-separated ids, e.g. twitter,linkedin)
SOCIAL_OAUTH_DISABLED_PROVIDERS=
# Force-enable providers even if listed in disabled set
SOCIAL_OAUTH_FORCE_ENABLED_PROVIDERS=
# OAuth state binding strict mode (session fingerprint + client binding)
OAUTH_STATE_BINDING_STRICT=true
# Refresh token persistence strategy: always | google | none
OAUTH_REFRESH_TOKEN_STRATEGY=always
# Auto account-linking policy: merge-by-email | strict-verified-email | separate-account
SOCIAL_ACCOUNT_LINKING_POLICY=merge-by-email

# ==========================================================
# 14) Payments / Finance Integrations
# ==========================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment abuse/risk guard tuning
PAYMENT_TOKEN_TTL_MS=120000
PAYMENT_IP_WINDOW_HOURS=24
PAYMENT_IP_DISTINCT_USERS_THRESHOLD=2
PAYMENT_IP_MIN_OPERATIONS_FOR_AUTO_BLOCK=3
PAYMENT_IP_RISK_SCORE_BLOCK_THRESHOLD=80
PAYMENT_IP_AUTO_BLOCK_ENABLED=true
PAYMENT_IP_IGNORE_PRIVATE_RANGES=true

# ==========================================================
# 15) Push Notifications (Web + Mobile)
# ==========================================================
# Generate VAPID keys once with:
# npx web-push generate-vapid-keys
# Browser push public key (legacy fallback; optional because client now fetches from backend API)
VITE_VAPID_PUBLIC_KEY=replace_with_generated_vapid_public_key

# Web Push (server-side VAPID for background notifications)
WEB_PUSH_VAPID_PUBLIC_KEY=replace_with_generated_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=replace_with_generated_vapid_private_key
WEB_PUSH_VAPID_SUBJECT=mailto:support@vex-games.com

# Firebase Admin (mobile/web push backend integrations)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ==========================================================
# 16) Mobile App Release / Force Update Metadata
# ==========================================================
# Store listing URLs shown in the app are managed from Admin panel app settings (DB).
APP_RELEASE_VERSION=1.0.0
RELEASE_VERSION=1.0.0
APP_RELEASED_AT=2026-01-01T00:00:00Z
BUILD_TIMESTAMP=2026-01-01T00:00:00Z
APP_NATIVE_LATEST_VERSION=
APP_UPDATE_URL_ANDROID=
APP_UPDATE_URL_IOS=
APP_FORCE_UPDATE=false

# Android release signing (for local CI/release build scripts)
# Keep passwords in secret manager and inject at runtime; do not commit real values.
KEYSTORE_PATH=android/keystore/vex-release-official.jks
KEY_ALIAS=vex_release_official
KEYSTORE_PASSWORD=replace_with_keystore_store_password
KEY_PASSWORD=replace_with_keystore_key_password

# ==========================================================
# 17) Translation Integrations (Optional)
# ==========================================================
TRANSLATE_API_KEY=
TRANSLATE_API_URL=

# ==========================================================
# 18) Security / QA Smoke Scripts (Optional Ops)
# ==========================================================
BASE_URL=https://vixo.click
SECURITY_BASE_URL=https://vixo.click
CSP_BASE_URL=https://vixo.click
WS_SMOKE_BASE_URL=https://vixo.click

SMOKE_TIMEOUT_MS=12000
SMOKE_PASSWORD=SmokePass123!
SMOKE_RECONNECT_SLA_MS=2000
SMOKE_RECONNECT_ROUNDS=3
SMOKE_RESET_SENSITIVE_LIMITER=false

WS_SMOKE_TIMEOUT_MS=12000
WS_SMOKE_HEARTBEAT_WAIT_MS=55000

SMOKE_SAM9_MODE=competitive
SMOKE_SAM9_FIXED_FEE=2
SMOKE_SAM9_CHALLENGE_STAKE=10

SMOKE_DOMINO_PROFILE=all
SMOKE_DOMINO_LATENCY_ROUNDS=20
SMOKE_DOMINO_LATENCY_P95_MS=1200
SMOKE_DOMINO_LOAD_CONCURRENCY=12
SMOKE_DOMINO_LOAD_BURSTS=3
SMOKE_DOMINO_LOAD_HOLD_MS=1000
SMOKE_DOMINO_LOAD_P95_MS=1800
SMOKE_DOMINO_LOAD_MIN_SUCCESS=0.90

ADMIN_SMOKE_PASSWORD=

# ==========================================================
# 19) Platform-managed / Internal (Usually do not set manually)
# ==========================================================
# REPLIT=
# REPL_ID=
# CLUSTER_WORKER=
