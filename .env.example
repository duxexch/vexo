VITE_VAPID_PUBLIC_KEY=BMg87oiu-lQ6k6Mhi1amiy1YiVDTzCoeHWECl5DjH0c3PM_49Mt-DTE_b-vCJSyL45czWP1ESg4ZWc_hDaN8RqI
VAPID_PRIVATE_KEY=__REDACTED_USE_REPLIT_SECRETS__

