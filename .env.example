# ========================================
# VEX Platform - Environment Variables Template
# Copy this file to .env.production and fill in your values
# ========================================

# ========================================
# DATABASE (Required)
# ========================================
POSTGRES_USER=vex_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vex_db

# ========================================
# REDIS (Required)
# ========================================
REDIS_PASSWORD=your_secure_redis_password_here

# ========================================
# MINIO OBJECT STORAGE (Required for file uploads)
# ========================================
MINIO_ROOT_USER=vex_minio_admin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_BUCKET=vex-uploads

# ========================================
# APPLICATION (Required)
# ========================================
NODE_ENV=production
PORT=3001
TZ=UTC
DB_SSL=false
DB_POOL_MAX=30
DB_POOL_MIN=5

# ========================================
# MIGRATIONS
# ========================================
# First deploy: SKIP=false, FORCE=true, SEED=true
# After first deploy: SKIP=true, FORCE=false, SEED=false
SKIP_MIGRATIONS=false
ALLOW_FORCE_MIGRATIONS=true
SEED_DATABASE=true

# ========================================
# SECURITY SECRETS (Required — minimum 32 characters each!)
# Generate: openssl rand -hex 64
# ========================================
SESSION_SECRET=your_64_char_session_secret_here
JWT_SIGNING_KEY=your_64_char_jwt_signing_key_here
ADMIN_JWT_SECRET=your_64_char_admin_jwt_secret_here
# NOTE: In docker-compose, JWT_SIGNING_KEY maps to JWT_USER_SECRET
# and ADMIN_JWT_SECRET maps to JWT_ADMIN_SECRET for the Node.js app

# ========================================
# ADMIN BOOTSTRAP
# ========================================
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=your_admin_password
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_RECOVERY_EMAIL=admin@yourdomain.com

# Leave empty to skip admin reset on restart
ADMIN_RESET_PASSWORD=
ADMIN_RESET_USERNAME=
ADMIN_RESET_EMAIL=

# ========================================
# OPTIONAL SERVICES (uncomment to enable)
# ========================================

# SMS/OTP - Twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Email - SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Google OAuth
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret

# Facebook OAuth
# FACEBOOK_APP_ID=your_app_id
# FACEBOOK_APP_SECRET=your_app_secret

# Telegram Bot
# TELEGRAM_BOT_TOKEN=your_bot_token

# Stripe Payments
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Firebase Push Notifications
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
