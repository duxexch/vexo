# Android release signing (for local CI/release build scripts)
# Keep passwords in secret manager and inject at runtime; do not commit real values.
# On Replit, store the four ANDROID_* values as Secrets — see replit.md
# § "Android Release Signing". The build script (scripts/mobile-android-build.mjs)
# refuses to run a release build unless all four are populated.
ANDROID_KEYSTORE_PATH=android/keystore/vex-release-official.jks
ANDROID_KEY_ALIAS=vex_release_official
ANDROID_KEYSTORE_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
ANDROID_KEY_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__


