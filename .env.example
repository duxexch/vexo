# =============================================================
# VEX Platform - Production Environment (Normalized)
# =============================================================

# -----------------------------
# Core App
# -----------------------------
NODE_ENV=production
PORT=3001
APP_PORT=3001
APP_URL=https://vixo.click
TZ=UTC
LOG_LEVEL=INFO
LOG_DIR=./logs
TRAEFIK_EXTERNAL_NETWORK=vex-traefik

# Email used by Traefik for Let's Encrypt certificate registration.
# REQUIRED when deploying deploy/docker-compose.traefik.yml.
ACME_EMAIL=admin@vixo.click

# -----------------------------
# SEO / Prerender.io
# -----------------------------
# Set to your Prerender API token from https://dashboard.prerender.io
PRERENDER_TOKEN=
# Optional: override service endpoint if needed
PRERENDER_SERVICE_URL=https://service.prerender.io
# Optional: upstream timeout in milliseconds
PRERENDER_TIMEOUT_MS=10000

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_USER=vex_user
POSTGRES_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
POSTGRES_DB=vex_db
DATABASE_URL=postgresql://vex_user:__REDACTED_USE_REPLIT_SECRETS__@vex-db:5432/vex_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=30
DB_POOL_MIN=5

# -----------------------------
# Redis
# -----------------------------
REDIS_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
REDIS_URL=redis://:__REDACTED_USE_REPLIT_SECRETS__@vex-redis:6379

# -----------------------------
# MinIO Object Storage
# -----------------------------
MINIO_ROOT_USER=vex_minio_admin
MINIO_ROOT_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
MINIO_BUCKET=vex-uploads
MINIO_ENDPOINT=vex-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=vex_minio_admin
MINIO_SECRET_KEY=__REDACTED_USE_REPLIT_SECRETS__
MINIO_USE_SSL=false

# -----------------------------
# Auth and Security Secrets
# -----------------------------
SESSION_SECRET=__REDACTED_USE_REPLIT_SECRETS__
JWT_SIGNING_KEY=__REDACTED_USE_REPLIT_SECRETS__
ADMIN_JWT_SECRET=__REDACTED_USE_REPLIT_SECRETS__
SECRETS_ENCRYPTION_KEY=__REDACTED_USE_REPLIT_SECRETS__

# Compatibility aliases (must match JWT_SIGNING_KEY / ADMIN_JWT_SECRET above)
JWT_USER_SECRET=__REDACTED_USE_REPLIT_SECRETS__
JWT_ADMIN_SECRET=__REDACTED_USE_REPLIT_SECRETS__

ENFORCE_SESSION_FINGERPRINT=true
VEX_DEV_MODE=false

# -----------------------------
# Admin Bootstrap and Recovery
# -----------------------------
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
ADMIN_BOOTSTRAP_EMAIL=info@vixo.click
ADMIN_RECOVERY_EMAIL=info@vixo.click

ADMIN_RESET_USERNAME=admin
ADMIN_RESET_PASSWORD=__REDACTED_USE_REPLIT_SECRETS__
ADMIN_RESET_EMAIL=duxexch@gmail.com
# -----------------------------
# Startup / Migration Controls
# -----------------------------
SKIP_MIGRATIONS=false
ALLOW_FORCE_MIGRATIONS=false
SEED_DATABASE=true
MIGRATION_TIMEOUT=120

# -----------------------------
# AI Agent Integration (App)
# -----------------------------
AI_AGENT_ENABLED=true
AI_AGENT_BASE_URL=http://vex-ai-agent:3100
AI_AGENT_SHARED_TOKEN=__REDACTED_USE_REPLIT_SECRETS__
AI_AGENT_TIMEOUT_MS=900
AI_AGENT_PAYLOAD_SALT=__REDACTED_USE_REPLIT_SECRETS__

# -----------------------------
# AI Agent Service Runtime
# -----------------------------
AI_AGENT_NAME=sam9
AI_AGENT_DATA_DIR=/app/data
AI_AGENT_PRIVACY_SALT=__REDACTED_USE_REPLIT_SECRETS__
AI_AGENT_MAX_RAW_EVENTS=5000
AI_AGENT_MAX_PROJECT_SNAPSHOTS=300

# -----------------------------
# Optional Runtime Scaling
# -----------------------------
NODE_CLUSTER_ENABLED=false
WEB_CONCURRENCY=2

# -----------------------------
# Email (Optional)
# -----------------------------
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@vixo.click
SMTP_PASS=__REDACTED_USE_REPLIT_SECRETS__
SMTP_FROM=info@vixo.click

SENDGRID_API_KEY=
SENDGRID_FROM=info@vixo.click
SENDGRID_FROM_EMAIL=info@vixo.click

# -----------------------------
# SMS (Optional)
# -----------------------------
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_WEBHOOK_URL=

# -----------------------------
# OAuth / Social (Optional)
# -----------------------------
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_SCOPES=openid,email,profile
GOOGLE_ANDROID_CLIENT_ID=replace_with_google_android_client_id
GOOGLE_CLIENT_ID_ANDROID=replace_with_google_android_client_id
GOOGLE_ANDROID_LOGIN_MODE=sdk-only
GOOGLE_ANDROID_ALLOW_WEB_CLIENT_FALLBACK=false
GOOGLE_ALLOWED_AUDIENCES=
GOOGLE_REQUEST_OFFLINE_ACCESS=false
GOOGLE_ANDROID_PACKAGE_NAME=click.vixo.app
GOOGLE_ANDROID_SHA1=7F:8D:A0:CB:12:42:1A:7F:90:6D:43:2E:6C:C2:96:1A:DD:AE:C8:B8
GOOGLE_ANDROID_SHA256=46:67:5A:1E:EA:17:A4:76:B9:1F:B3:11:3F:13:6F:85:3E:8B:65:BC:48:24:6C:91:BB:0E:BD:25:E7:EA:A5:CB

# OAuth runtime safety and policy flags
# Disable providers globally (comma-separated ids, e.g. twitter,linkedin)
SOCIAL_OAUTH_DISABLED_PROVIDERS=
# Force-enable providers even if listed in disabled set
SOCIAL_OAUTH_FORCE_ENABLED_PROVIDERS=
# OAuth state binding strict mode (session fingerprint + client binding)
OAUTH_STATE_BINDING_STRICT=true
# Refresh token persistence strategy: always | google | none
OAUTH_REFRESH_TOKEN_STRATEGY=always
# Auto account-linking policy: merge-by-email | strict-verified-email | separate-account
SOCIAL_ACCOUNT_LINKING_POLICY=merge-by-email

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TELEGRAM_BOT_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# -----------------------------
# Payments / Push (Optional)
# -----------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PRIVATE KEY-----\n"

# Apple PushKit / VoIP push credentials — wakes a killed iOS app so the
# CallKit lock-screen UI can ring. Generated at developer.apple.com → Keys
# (one .p8 key, capability "Apple Push Notifications service (APNs)" — same
# key works for alert + VoIP topics). Server appends `.voip` to bundleId
# automatically, so APNS_BUNDLE_ID should be the plain app id.
# Run `npm run ops:voip-push-doctor` after setting these to verify the
# credentials sign a valid JWT and Apple/Google accept the auth handshake.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=click.vixo.app
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_P8_CONTENTS\n-----END PRIVATE KEY-----\n"
# Optional — flip to https://api.sandbox.push.apple.com while testing on
# TestFlight; leave blank in production.
APNS_HOST=
APNS_USE_SANDBOX=


# ==========================================================
# 16) Voice Stack (LiveKit + coturn)
# ==========================================================
# LiveKit API keys format: "key1: secret1, key2: secret2"
# For production, generate a strong secret per environment (see deploy/voice/bootstrap-prod-voice.sh)
LIVEKIT_KEYS=vixo_prod: replace_with_livekit_secret

# ----------------------------------------------------------
# coturn TURN/STUN — CANONICAL ephemeral-credential setup
# ----------------------------------------------------------
# coturn (deploy/coturn/turnserver.conf.template) runs in `use-auth-secret`
# mode: it ONLY accepts HMAC-SHA1-signed time-limited credentials issued by
# the backend `/api/rtc/ice-servers` endpoint. The static `TURN_USERNAME` /
# `TURN_PASSWORD` / `PUBLIC_RTC_TURN_*` variables below are LEGACY/UNUSED in
# this configuration — leaving them at the placeholder is fine; coturn will
# reject any static credential pair anyway.
#
# All four `TURN_*` variables below MUST be filled with real values for voice
# to work. `prod-auto.sh` will auto-generate `TURN_STATIC_SECRET` and detect
# `TURN_EXTERNAL_IP` automatically when run on the VPS.
TURN_HOST=turn.vixo.click
TURN_REALM=vixo.click
TURN_EXTERNAL_IP=your.public.ip.address
TURN_STATIC_SECRET=replace_with_strong_turn_secret
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_TTL_SECONDS=3600
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Optional compose profile (set to empty string to disable the coturn container)
TURN_COMPOSE_PROFILE=coturn

# ----------------------------------------------------------
# LEGACY static-credential fallback (DO NOT rely on these)
# ----------------------------------------------------------
# Kept only for environments running coturn WITHOUT `use-auth-secret` (very
# rare). Production deployments with the bundled coturn config MUST leave
# these untouched — `/api/rtc/ice-servers` is the canonical credential
# source, not `/api/settings/public`.
TURN_USERNAME=vex_turn_user
TURN_PASSWORD=replace_with_strong_turn_password
PUBLIC_RTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
PUBLIC_RTC_TURN_URLS=
PUBLIC_RTC_TURN_USERNAME=
PUBLIC_RTC_TURN_CREDENTIAL=
# all | relay
PUBLIC_RTC_ICE_TRANSPORT_POLICY=all

# -----------------------------
# Translation Service (Optional)
# -----------------------------
TRANSLATE_API_KEY=
TRANSLATE_API_URL=

# -----------------------------
# Browser Push (Client)
